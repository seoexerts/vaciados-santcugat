---
import BaseLayout from '../layouts/BaseLayout.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { ciudades, EMPRESA } from '../data/index';
import { siteConfig } from '../config/site';
import { content } from '../config/content';

const mainCiudad = ciudades[0];
// Helper: reemplaza {{city}} por la ciudad principal
const c = (str: string) => str.replace(/\{\{city\}\}/g, siteConfig.mainCity);

const canonical   = `${siteConfig.web}/`;
const title       = `${content.hero.h1main} en ${siteConfig.mainCity} – Presupuesto gratis | ${siteConfig.businessName}`;
const description = `${content.hero.description} Llama al ${siteConfig.phone}.`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <LocalBusinessSchema ciudad={mainCiudad} servicio={mainCiudad.servicios[0]} url={canonical} slot="head" />
  <BreadcrumbSchema items={[{ name: 'Inicio', url: canonical }]} slot="head" />

  <!-- ① HERO LOCAL ─────────────────────────────────────── -->
  <section class="hero" aria-label="Presentación del servicio">
    <div class="container hero-inner">

      <div class="hero-text">
        <span class="eyebrow hero-eyebrow">{c(content.hero.eyebrow)}</span>

        <h1>
          {content.hero.h1main}<br />
          <span class="hero-h1-accent">{c(content.hero.h1accent)}</span>
        </h1>

        <p class="hero-sub">{content.hero.description}</p>

        <div class="hero-ctas">
          <a href={`tel:${mainCiudad.telefono.replace(/\s/g,'')}`} class="btn btn-primary btn-lg">
            📞 Llamar ahora — {mainCiudad.telefono}
          </a>
          <a href="#contacto-form" class="btn btn-ghost btn-lg">
            Pedir presupuesto gratis
          </a>
        </div>

        <ul class="hero-badges" aria-label="Ventajas del servicio">
          <li><span aria-hidden="true">⚡</span> {content.hero.badge1}</li>
          <li><span aria-hidden="true">🏠</span> {content.hero.badge2}</li>
          <li><span aria-hidden="true">♻️</span> {content.hero.badge3}</li>
          <li><span aria-hidden="true">✅</span> {content.hero.badge4}</li>
        </ul>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="hero-card">
          <div class="hero-card-header">
            <span class="status-dot"></span>
            <span>Disponible ahora en {siteConfig.mainCity}</span>
          </div>
          <p class="hero-card-stat">{content.hero.cardStat}</p>
          <p class="hero-card-label">{content.hero.cardLabel}</p>
          <div class="hero-card-metrics">
            <div><strong>{ciudades.length}</strong><span>municipios</span></div>
            <div><strong>24 h</strong><span>presupuesto</span></div>
            <div><strong>4,9 ★</strong><span>valoración</span></div>
          </div>
          <hr class="hero-card-divider" />
          <p class="hero-card-caption">Zona de actuación</p>
          <div class="hero-card-cities">
            {ciudades.map(c => <span>{c.nombre}</span>)}
          </div>
        </div>
      </div>

    </div>

    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <!-- ② BENEFICIOS / POR QUÉ ELEGIRNOS ────────────────── -->
  <section class="sec sec--tint" aria-labelledby="beneficios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="beneficios-heading">¿Por qué elegirnos en {siteConfig.mainCity}?</h2>
        <p class="section-sub">{content.sections.beneficiosSub}</p>
      </div>

      <ul class="benefits-grid" role="list">
        {content.benefits.map(b => (
          <li class="benefit-card">
            <div class="benefit-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>{c(b.title)}</h3>
            <p>{c(b.description)}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ③ SERVICIOS DETALLADOS ──────────────────────────── -->
  <section class="sec" aria-labelledby="servicios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="servicios-heading">Nuestros servicios en {siteConfig.mainCity}</h2>
        <p class="section-sub">{content.sections.serviciosSub}</p>
      </div>

      <p class="srv-grid-intro">
        Servicios de <a href="/servicios/">{siteConfig.serviceType} en {siteConfig.mainCity}</a>. Equipo propio, presupuesto gratuito y atención personalizada.
      </p>

      <ul class="srv-grid" role="list">
        {content.serviceSummaries.map(srv => (
          <li class={`srv-card${srv.featured ? ' srv-card--featured' : ''}`}>
            {srv.featured && <div class="srv-card-badge">Más solicitado</div>}
            <div class="srv-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3>{srv.nombre}</h3>
            <p>{srv.description}</p>
            <ul class="srv-features">
              {srv.features.map(f => <li>✓ {f}</li>)}
            </ul>
            {srv.ctaPage
              ? <a href={`/${mainCiudad.slug}/${srv.slug}/`} class="btn btn-primary">Ver servicio →</a>
              : <a href="/contacto" class="btn btn-primary">Solicitar presupuesto →</a>
            }
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ④ ZONA DE ACTUACIÓN ──────────────────────────────── -->
  <section class="sec sec--tint" aria-labelledby="zona-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="zona-heading">Zona de actuación: {siteConfig.mainCity} y alrededores</h2>
        <p class="section-sub">Cubrimos {siteConfig.mainCity} y {ciudades.length - 1} municipios de la comarca. Desplazamiento incluido en el presupuesto.</p>
      </div>

      <ul class="zona-grid" role="list">
        {ciudades.map(ciudad => (
          <li class="zona-card">
            <div class="zona-card-header">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M8 1.5C5.52 1.5 3.5 3.52 3.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.48-2.02-4.5-4.5-4.5z"/><circle cx="8" cy="6" r="1.5"/>
              </svg>
              <strong>{ciudad.nombre}</strong>
            </div>
            <ul class="zona-services">
              {ciudad.servicios.map(s => (
                <li>
                  <a href={`/${ciudad.slug}/${s.slug}/`}>{s.nombre} en {ciudad.nombre}</a>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>

      <div class="zona-barrios">
        <p class="zona-barrios-label">También en los barrios de {siteConfig.mainCity}:</p>
        <ul class="zona-tags" role="list">
          {mainCiudad.zonas.map(z => <li>{z}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ⑤ PROCESO DE TRABAJO ─────────────────────────────── -->
  <section class="sec" aria-labelledby="proceso-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="proceso-heading">Cómo trabajamos: 4 pasos sin complicaciones</h2>
        <p class="section-sub">Un proceso claro y transparente desde el primer contacto hasta la entrega del inmueble vacío.</p>
      </div>

      <ol class="proceso-steps">
        {content.proceso.map((paso, i) => (
          <li>
            <div class="proceso-num" aria-hidden="true">{i + 1}</div>
            <div class="proceso-content">
              <h3>{paso.titulo}</h3>
              <p>{paso.descripcion}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ⑥ TESTIMONIOS ────────────────────────────────────── -->
  <section class="sec sec--dark" aria-labelledby="testimonios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="testimonios-heading">Lo que dicen nuestros clientes en {siteConfig.mainCity}</h2>
        <p class="section-sub-dark">{content.sections.testimoniosSub}</p>
      </div>

      <div class="testimonios-track" role="list">
        {content.testimonials.map(t => (
          <article class="testimonio-card" role="listitem">
            <div class="testimonio-stars" aria-label="5 estrellas">★★★★★</div>
            <blockquote><p>"{t.quote}"</p></blockquote>
            <footer>
              <div class="testimonio-avatar">{t.initials}</div>
              <div>
                <cite class="testimonio-nombre">{t.name}</cite>
                <span class="testimonio-lugar">{c(t.location)} · {t.service}</span>
              </div>
            </footer>
          </article>
        ))}
      </div>

      <div class="testimonio-hint" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 8l6 6 6-6"/></svg>
        Desliza para ver más
      </div>
    </div>
  </section>

  <!-- ⑦ PRECIOS ORIENTATIVOS ───────────────────────────── -->
  <section class="sec sec--tint" aria-labelledby="precios-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="precios-heading">Precios orientativos en {siteConfig.mainCity}</h2>
        <p class="section-sub">{content.sections.preciosSub}</p>
      </div>

      <ul class="precios-grid" role="list">
        {content.pricing.map(p => (
          <li class={`precio-card${p.highlight ? ' precio-card--highlight' : ''}`}>
            {p.highlight && 'badge' in p && <div class="precio-badge">{(p as any).badge}</div>}
            <div class="precio-tipo">{p.tipo}</div>
            <div class="precio-desde">desde</div>
            <div class="precio-valor">{p.precio}</div>
            <ul class="precio-incl">
              {p.features.map(f => <li>{f}</li>)}
            </ul>
            <a href={`tel:${mainCiudad.telefono.replace(/\s/g,'')}`}
               class={`btn btn-full ${p.highlight ? 'btn-white' : 'btn-primary'}`}>
              Pedir precio exacto
            </a>
          </li>
        ))}
      </ul>

      <p class="precios-aviso">* {c(content.sections.preciosNota)}</p>
    </div>
  </section>

  <!-- ⑧ FAQ ESPECÍFICAS ────────────────────────────────── -->
  <section class="sec" aria-labelledby="faq-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="faq-heading">Preguntas frecuentes en {siteConfig.mainCity}</h2>
        <p class="section-sub">{content.sections.faqSub}</p>
      </div>

      <div class="faq-list">
        {content.faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0 || undefined}>
            <summary>
              <span>{c(faq.pregunta)}</span>
              <svg class="faq-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 8l5 5 5-5"/>
              </svg>
            </summary>
            <p>{faq.respuesta}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑨ CTA FINAL + CONTACTO ───────────────────────────── -->
  <section class="sec sec--dark cta-final" id="contacto-form" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-grid">

        <!-- Formulario -->
        <div class="cta-form-wrap">
          <h2 id="cta-heading">Pide tu presupuesto gratuito ahora</h2>
          <p class="cta-form-sub">Sin compromiso. Te respondemos en menos de 24 horas laborables.</p>

          <form
            class="cta-form"
            name="contacto-home"
            method="POST"
            action="/gracias/"
            data-netlify="true"
            netlify-honeypot="bot-field"
            novalidate
          >
            <input type="hidden" name="form-name" value="contacto-home" />
            <p class="visually-hidden">
              <label>No rellenar: <input name="bot-field" /></label>
            </p>

            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre <abbr title="Obligatorio">*</abbr></label>
                <input id="nombre" name="nombre" type="text" placeholder="Tu nombre" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="telefono">Teléfono <abbr title="Obligatorio">*</abbr></label>
                <input id="telefono" name="telefono" type="tel" placeholder="+34 600 000 000" required autocomplete="tel" />
              </div>
            </div>

            <div class="form-group">
              <label for="servicio-form">Servicio <abbr title="Obligatorio">*</abbr></label>
              <select id="servicio-form" name="servicio" required>
                <option value="">¿Qué necesitas?</option>
                {content.serviceSummaries.map(s => (
                  <option value={s.slug}>{s.nombre}</option>
                ))}
              </select>
            </div>

            <div class="form-group">
              <label for="mensaje-form">Cuéntanos más <span class="form-optional">(opcional)</span></label>
              <textarea id="mensaje-form" name="mensaje" rows="3" placeholder="Tamaño aproximado, ciudad, urgencia…"></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg btn-full">
              Enviar solicitud de presupuesto →
            </button>
            <p class="form-legal">
              Al enviar aceptas nuestra <a href="/privacidad/">política de privacidad</a>.
            </p>
          </form>
        </div>

        <!-- Datos de contacto -->
        <aside class="cta-contact">
          <h3>Contacto directo</h3>

          <address class="cta-address">
            <a href={`tel:${mainCiudad.telefono.replace(/\s/g,'')}`} class="cta-contact-item cta-contact-item--primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/>
              </svg>
              <div>
                <span class="cta-contact-label">Llamar ahora</span>
                <span class="cta-contact-value">{mainCiudad.telefono}</span>
              </div>
            </a>

            <a
              href={`https://wa.me/${siteConfig.whatsapp}?text=Hola%2C%20quiero%20un%20presupuesto%20para%20vaciado%20en%20${encodeURIComponent(siteConfig.mainCity)}`}
              class="cta-contact-item"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.135.561 4.14 1.542 5.876L0 24l6.312-1.518A11.956 11.956 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.897 0-3.67-.502-5.2-1.376L3 22l1.395-4.698A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              <div>
                <span class="cta-contact-label">WhatsApp</span>
                <span class="cta-contact-value">Escríbenos ahora</span>
              </div>
            </a>

            <div class="cta-contact-item cta-contact-item--info">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              <div>
                <span class="cta-contact-label">Dirección</span>
                <span class="cta-contact-value">{mainCiudad.direccion}, {mainCiudad.codigoPostal} {mainCiudad.nombre}</span>
              </div>
            </div>

            <div class="cta-contact-item cta-contact-item--info">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              <div>
                <span class="cta-contact-label">Horario</span>
                <span class="cta-contact-value">{siteConfig.horarioTexto}</span>
              </div>
            </div>
          </address>

          <div class="cta-trust">
            <div class="trust-item"><span aria-hidden="true">✓</span> Presupuesto gratuito en 24 h</div>
            <div class="trust-item"><span aria-hidden="true">✓</span> Sin compromiso</div>
            <div class="trust-item"><span aria-hidden="true">✓</span> Equipo propio certificado</div>
            <div class="trust-item"><span aria-hidden="true">✓</span> Gestión de residuos legalizada</div>
          </div>
        </aside>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ══════════════════════════════════════════════════════
     SECCIONES BASE
  ══════════════════════════════════════════════════════ */
  .sec          { padding-block: 4.5rem; }
  .sec--tint    { background: var(--c-bg-tint); }
  .sec--dark    { background: var(--c-bg-dark); }
  @media (max-width: 768px) { .sec { padding-block: 3rem; } }

  .section-sub-dark {
    color: rgba(255,255,255,.6);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: .75rem;
  }

  /* ══════════════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════════════ */
  .hero {
    background: var(--c-hero-gradient);
    padding-block: 5.5rem 0;
    margin-top: var(--header-h);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.05) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 60% at 75% 10%, rgba(0,100,255,.3) 0%, transparent 65%),
      radial-gradient(ellipse 40% 40% at 15% 90%, rgba(80,80,200,.18) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: 4.5rem;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 920px) {
    .hero-inner { grid-template-columns: 1fr 340px; align-items: center; gap: 4rem; }
  }

  .hero-text { color: #fff; }
  .hero-eyebrow {
    color: rgba(255,255,255,.9);
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
  }
  .hero-text h1 { color: #fff; margin-block: .75rem 1rem; }
  .hero-h1-accent {
    background: linear-gradient(90deg, #93c5fd, #c4b5fd);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,.78);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 2rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; }
    .hero-ctas .btn { width: 100%; justify-content: center; }
  }
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    list-style: none;
  }
  .hero-badges li {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .78rem;
    font-weight: 500;
    color: rgba(255,255,255,.88);
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 100px;
    padding: .3rem .8rem;
    white-space: nowrap;
  }

  /* Tarjeta lateral del hero */
  .hero-card {
    background: rgba(255,255,255,.08);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,.16);
    border-radius: var(--r-xl);
    padding: 1.75rem;
    color: #fff;
    box-shadow: 0 20px 50px rgba(0,0,0,.35), 0 0 0 1px rgba(255,255,255,.05);
  }
  .hero-card-header {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .72rem;
    font-weight: 600;
    color: rgba(255,255,255,.5);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: .07em;
  }
  .status-dot {
    width: 8px; height: 8px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(34,197,94,.25);
    animation: pulse 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
