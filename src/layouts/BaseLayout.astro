---
/**
 * Layout compartido para todas las páginas.
 * Incluye: HTML shell, Inter font, header fijo con nav por rutas,
 * footer y todos los estilos globales (tokens, reset, botones, etc.).
 */
import SEOHead from '../components/SEOHead.astro';
import { EMPRESA, ciudades } from '../data/index';
const mainCity = ciudades[0];
const waPhone = mainCity.telefono.replace(/[^0-9]/g, '');
// siteConfig es la fuente de verdad. Edita src/config/site.ts para
// personalizar businessName, serviceType, area, phone, etc.
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = siteConfig.web + Astro.url.pathname } = Astro.props;

// Resalta el enlace activo comparando con la ruta actual
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const navLinks = [
  { href: '/',              label: 'Inicio' },
  { href: '/sobre-nosotros', label: 'Quiénes somos' },
  { href: '/servicios',      label: 'Servicios' },
  { href: '/faq',            label: 'FAQ' },
  { href: '/contacto',       label: 'Contacto' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <SEOHead title={title} description={description} canonical={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Carga de fuente non-blocking: no bloquea el render -->
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    </noscript>
    <slot name="head" />
    <!-- Colores corporativos dinámicos desde siteConfig -->
    <style set:html={`
      :root {
        --c-primary:   ${siteConfig.colorPrimary};
        --c-primary-d: color-mix(in srgb, ${siteConfig.colorPrimary} 78%, #000);
        --c-primary-l: color-mix(in srgb, ${siteConfig.colorPrimary}  8%, #fff);
        --c-text:      ${siteConfig.colorText};
        --c-bg-dark:   color-mix(in srgb, ${siteConfig.colorText} 95%, #000);
        --c-hero-from: color-mix(in srgb, ${siteConfig.colorPrimary} 12%, #000);
        --c-hero-mid:  color-mix(in srgb, ${siteConfig.colorPrimary} 22%, #000);
        --c-hero-gradient: linear-gradient(150deg, var(--c-hero-from) 0%, var(--c-hero-mid) 50%, ${siteConfig.colorPrimary} 100%);
      }
    `} />
  </head>

  <body>

    <!-- ── Header fijo ──────────────────────────────────── -->
    <header class="site-header">
      <div class="container header-inner">

        <a href="/" class="brand" aria-label="Ir al inicio">
          <span class="brand-icon" aria-hidden="true">◈</span>
          <span class="brand-name">{EMPRESA.nombre}</span>
        </a>

        <nav class="main-nav" aria-label="Navegación principal">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>

        <a href="/contacto" class="btn btn-sm btn-cta-header">
          <span class="cta-full">📋 PRESUPUESTO GRATIS</span>
          <span class="cta-short">PRESUPUESTO</span>
        </a>

        <button
          class="nav-toggle"
          aria-label="Abrir menú"
          aria-expanded="false"
          onclick="this.setAttribute('aria-expanded',
            this.getAttribute('aria-expanded')==='false' ? 'true' : 'false');
            document.querySelector('.main-nav').classList.toggle('open')"
        >
          <span></span><span></span><span></span>
        </button>

      </div>
    </header>

    <!-- ── Contenido de la página ────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Mapa ──────────────────────────────────────────── -->
    <div class="footer-map-wrap" aria-label={`Ubicación de ${EMPRESA.nombre} en ${mainCity.nombre}`}>
      <iframe
        src={`https://maps.google.com/maps?q=${mainCity.lat},${mainCity.lng}&z=15&output=embed`}
        width="100%"
        height="260"
        style="border:0;display:block;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Mapa de ${EMPRESA.nombre} en ${mainCity.nombre}`}
      ></iframe>
    </div>

    <!-- ── Footer ────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="brand-icon" aria-hidden="true">◈</span>
          <span class="brand-name">{EMPRESA.nombre}</span>
        </div>

        <nav class="footer-nav" aria-label="Navegación footer">
          {navLinks.map(({ href, label }) => (
            <a href={href}>{label}</a>
          ))}
        </nav>

        <p class="footer-legal">
          &copy; {new Date().getFullYear()} {EMPRESA.nombreLegal}
          &nbsp;·&nbsp;<a href="/privacidad/">Privacidad</a>
          &nbsp;·&nbsp;<a href="/aviso-legal/">Aviso legal</a>
        </p>
      </div>
    </footer>

    <!-- ── Barra CTA móvil (Llamar + WhatsApp) ──────────── -->
    <div id="mobile-cta-bar" class="mobile-cta-bar" hidden>
      <a href={`tel:${mainCity.telefono.replace(/\s/g,'')}`} class="mobile-cta-btn mobile-cta-btn--call">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/>
        </svg>
        Llamar ahora
      </a>
      <a href={`https://wa.me/${waPhone}`} class="mobile-cta-btn mobile-cta-btn--wa" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

    <script is:inline defer>
      (function () {
        var bar = document.getElementById('mobile-cta-bar');
        if (!bar || window.innerWidth > 768) return;
        window.addEventListener('scroll', function () {
          bar.hidden = window.scrollY < 200;
        }, { passive: true });
      })();
    </script>

    <!-- ── WhatsApp flotante ─────────────────────────── -->
    <a
      href={`https://wa.me/${waPhone}`}
      class="wa-float"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <!-- ── Volver arriba ────────────────────────────── -->
    <button id="back-to-top" class="back-to-top" aria-label="Volver arriba" hidden>
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 15V5M5 10l5-5 5 5"/>
      </svg>
    </button>

    <script is:inline defer>
      (function () {
        const btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function () {
          btn.hidden = window.scrollY < 400;
        }, { passive: true });
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>

    <!-- ── Cookie banner ─────────────────────────────── -->
    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-live="polite"
         aria-label="Aviso de cookies" hidden>
      <div class="cookie-inner">
        <p class="cookie-text">
          Usamos cookies técnicas necesarias para el funcionamiento del sitio.
          No utilizamos cookies de seguimiento ni publicidad.
          <a href="/privacidad/">Más información</a>.
        </p>
        <div class="cookie-actions">
          <button id="cookie-accept" class="cookie-btn cookie-btn--accept">
            Aceptar
          </button>
          <button id="cookie-reject" class="cookie-btn cookie-btn--reject">
            Rechazar
          </button>
        </div>
      </div>
    </div>

    <script is:inline defer>
      (function () {
        const KEY = 'cookie_consent';
        const banner = document.getElementById('cookie-banner');
        if (!banner) return;
        // Mostrar solo si el usuario no ha decidido aún
        if (!localStorage.getItem(KEY)) {
          banner.hidden = false;
        }
        document.getElementById('cookie-accept')?.addEventListener('click', function () {
          localStorage.setItem(KEY, 'accepted');
          banner.hidden = true;
        });
        document.getElementById('cookie-reject')?.addEventListener('click', function () {
          localStorage.setItem(KEY, 'rejected');
          banner.hidden = true;
        });
      })();
    </script>

  </body>
</html>

<style is:global>
  /* ══════════════════════════════════════════════════════════
     DESIGN TOKENS
  ══════════════════════════════════════════════════════════ */
  :root {
    --c-bg:        #ffffff;
    --c-bg-tint:   #f8fafc;
    --c-bg-dark:   #0f172a;
    --c-primary:   #0057ff;
    --c-primary-d: #0041cc;
    --c-primary-l: #eff6ff;
    --c-text:      #0f172a;
    --c-text-m:    #475569;
    --c-text-l:    #94a3b8;
    --c-border:    #e2e8f0;
    --c-white:     #ffffff;
    --c-green:     #22c55e;
    --c-whatsapp:  #25d366;

    --r-sm: 8px;
    --r-md: 12px;
    --r-lg: 18px;
    --r-xl: 24px;

    --sh-card: 0 1px 3px rgba(0,0,0,.07), 0 4px 16px rgba(0,0,0,.06);

    --font:     'Inter', system-ui, -apple-system, sans-serif;
    --max-w:    1140px;
    --header-h: 64px;
  }

  /* ══════════════════════════════════════════════════════════
     RESET + BASE
  ══════════════════════════════════════════════════════════ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--header-h);
    font-size: 16px;
  }

  body {
    font-family: var(--font);
    color: var(--c-text);
    background: var(--c-bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img, svg { display: block; max-width: 100%; }
  a { color: var(--c-primary); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ══════════════════════════════════════════════════════════
     LAYOUT HELPERS
  ══════════════════════════════════════════════════════════ */
  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: 1.25rem;
  }

  /* Sección genérica con padding vertical */
  .page-section          { padding-block: 5rem; }
  .page-section--tinted  { background: var(--c-bg-tint); }
  .page-section--dark    { background: var(--c-bg-dark); }
  @media (max-width: 768px) { .page-section { padding-block: 3.5rem; } }

  /* Cabecera centrada de sección */
  .section-header {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
    margin-bottom: 3rem;
  }
  .section-sub {
    color: var(--c-text-m);
    font-size: 1rem;
    line-height: 1.7;
    margin-top: .75rem;
  }

  /* ══════════════════════════════════════════════════════════
     TYPOGRAPHY
  ══════════════════════════════════════════════════════════ */
  h1 { font-size: clamp(2rem, 5vw, 3rem);   font-weight: 800; line-height: 1.15; letter-spacing: -.02em; }
  h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 700; line-height: 1.25; letter-spacing: -.015em; margin-top: .5rem; }
  h3 { font-size: 1.05rem; font-weight: 600; }

  .eyebrow {
    display: inline-block;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: var(--c-primary-l);
    padding: .25rem .75rem;
    border-radius: 100px;
    margin-bottom: .75rem;
  }
  .eyebrow--light {
    color: rgba(255,255,255,.8);
    background: rgba(255,255,255,.12);
  }

  /* ══════════════════════════════════════════════════════════
     BUTTONS
  ══════════════════════════════════════════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-family: var(--font);
    font-weight: 600;
    font-size: .9rem;
    padding: .55rem 1.25rem;
    border-radius: var(--r-sm);
    border: 2px solid transparent;
    cursor: pointer;
    transition: all .18s ease;
    white-space: nowrap;
    text-decoration: none;
    line-height: 1;
  }
  .btn:hover { text-decoration: none; }

  .btn--primary  { background: var(--c-primary);   color: #fff; border-color: var(--c-primary); }
  .btn--primary:hover { background: var(--c-primary-d); border-color: var(--c-primary-d); }

  .btn--ghost    { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
  .btn--ghost:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.7); }

  .btn--outline  { background: transparent; color: var(--c-primary); border-color: var(--c-primary); }
  .btn--outline:hover { background: var(--c-primary-l); }

  .btn--white    { background: #fff; color: var(--c-primary); border-color: #fff; }
  .btn--white:hover { background: #f0f4ff; }

  .btn--whatsapp { background: var(--c-whatsapp); color: #fff; border-color: var(--c-whatsapp); }
  .btn--whatsapp:hover { background: #1db550; }

  .btn--sm   { font-size: .8rem;  padding: .45rem 1rem; }
  .btn--lg   { font-size: 1rem;   padding: .8rem 1.75rem; }
  .btn--full { width: 100%; justify-content: center; }

  /* Aliases sin BEM para compatibilidad con código existente */
  .btn-primary  { background: var(--c-primary);   color: #fff; border-color: var(--c-primary); }
  .btn-primary:hover { background: var(--c-primary-d); }
  .btn-ghost    { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
  .btn-ghost:hover   { background: rgba(255,255,255,.1); }
  .btn-white    { background: #fff; color: var(--c-primary); border-color: #fff; }
  .btn-white:hover   { background: #f0f4ff; }
  .btn-whatsapp { background: var(--c-whatsapp); color: #fff; border-color: var(--c-whatsapp); }
  .btn-whatsapp:hover { background: #1db550; }
  .btn-sm   { font-size: .8rem;  padding: .45rem 1rem; }
  .btn-lg   { font-size: 1rem;   padding: .8rem 1.75rem; }
  .btn-full { width: 100%; justify-content: center; }

  /* ── CTA Header button ── */
  .btn-cta-header {
    background: linear-gradient(135deg, #ff6b00 0%, #ff3d00 100%);
    color: #fff !important;
    border-color: transparent;
    font-size: .82rem;
    font-weight: 700;
    padding: .55rem 1.25rem;
    border-radius: 8px;
    letter-spacing: .03em;
    box-shadow: 0 3px 12px rgba(255, 80, 0, .35);
    transition: transform .15s, box-shadow .15s, filter .15s;
    white-space: nowrap;
    animation: ctaPulse 2.4s ease-in-out infinite;
  }
  .btn-cta-header:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
    box-shadow: 0 5px 18px rgba(255, 80, 0, .5);
    text-decoration: none;
    animation: none;
  }
  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 3px 12px rgba(255, 80, 0, .35); }
    50%       { box-shadow: 0 3px 22px rgba(255, 80, 0, .65); }
  }

  /* ══════════════════════════════════════════════════════════
     HEADER
  ══════════════════════════════════════════════════════════ */
  .site-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 100;
    height: var(--header-h);
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--c-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 100%;
    overflow: hidden;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--c-text);
    flex-shrink: 0;
    text-decoration: none;
  }
  .brand:hover { text-decoration: none; }
  .brand-icon  { color: var(--c-primary); font-size: 1.3rem; }

  .main-nav {
    display: flex;
    align-items: center;
    gap: .25rem;
    margin-inline-start: auto;
  }

  .main-nav a {
    font-size: .88rem;
    font-weight: 500;
    color: var(--c-text-m);
    padding: .4rem .75rem;
    border-radius: var(--r-sm);
    transition: all .15s;
    text-decoration: none;
  }
  .main-nav a:hover               { color: var(--c-primary); background: var(--c-primary-l); }
  .main-nav a[aria-current="page"] {
    color: var(--c-primary);
    background: var(--c-primary-l);
    font-weight: 600;
  }

  /* Hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .5rem;
    margin-inline-start: auto;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--c-text);
    border-radius: 2px;
    transition: all .2s;
  }

  /* ══════════════════════════════════════════════════════════
     FOOTER
  ══════════════════════════════════════════════════════════ */
  .footer-map-wrap {
    width: 100%;
    line-height: 0;
    border-top: 1px solid rgba(255,255,255,.06);
  }
  .footer-map-wrap iframe {
    filter: grayscale(30%) brightness(.9);
    transition: filter .3s;
  }
  .footer-map-wrap iframe:hover { filter: grayscale(0%) brightness(1); }

  .site-footer {
    background: #050d1a;
    padding-block: 2rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-brand { display: flex; align-items: center; gap: .4rem; font-weight: 600; font-size: .9rem; }
  .footer-brand .brand-icon { color: var(--c-primary); }
  .footer-brand .brand-name { color: rgba(255,255,255,.7); }

  .footer-nav { display: flex; flex-wrap: wrap; gap: .25rem; }
  .footer-nav a {
    font-size: .8rem;
